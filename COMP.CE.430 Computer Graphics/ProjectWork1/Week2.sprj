<?xml version="1.0"?>
<project version="2">
	<pipeline>
		<pass name="Simple" type="shader" active="true" patchverts="1">
			<shader type="vs" path="shaders\Week2_SimpleVS.glsl" entry="main" />
			<shader type="ps" path="shaders\Week2_SimplePS.glsl" entry="main" />
			<inputlayout>
				<item value="Position" semantic="POSITION" />
			</inputlayout>
			<rendertexture />
			<items>
				<item name="tri" type="geometry">
					<type>Triangle</type>
					<width>1</width>
					<height>1</height>
					<depth>1</depth>
					<y>0.229782879</y>
					<topology>TriangleList</topology>
				</item>
			</items>
			<itemvalues>
				<value variable="uTime" for="tri">
					<row>
						<value>37.9814186</value>
					</row>
				</value>
				<value variable="uResolution" for="tri">
					<row>
						<value>1510</value>
						<value>1321</value>
					</row>
				</value>
			</itemvalues>
			<variables>
				<variable type="float2" name="uResolution" system="ViewportSize" />
				<variable type="float" name="uTime" system="Time" />
			</variables>
			<macros />
		</pass>
		<pass name="model" type="shader" active="false" patchverts="1">
			<shader type="vs" path="shaders\Week2_modelVS.glsl" entry="main" />
			<shader type="ps" path="shaders\Week2_modelPS.glsl" entry="main" />
			<inputlayout>
				<item value="Position" semantic="POSITION" />
				<item value="Normal" semantic="NORMAL" />
				<item value="Texcoord" semantic="TEXCOORD0" />
			</inputlayout>
			<rendertexture />
			<items>
				<item name="flag" type="model">
					<filepath>shaders\models\flag.glb</filepath>
					<grouponly>false</grouponly>
				</item>
				<item name="flagpole" type="model">
					<filepath>shaders\models\flagpole.glb</filepath>
					<grouponly>false</grouponly>
				</item>
				<item name="house" type="model">
					<filepath>shaders\models\house.glb</filepath>
					<grouponly>false</grouponly>
				</item>
				<item name="roof" type="model">
					<filepath>shaders\models\roof.glb</filepath>
					<grouponly>false</grouponly>
				</item>
				<item name="ground" type="model">
					<filepath>shaders\models\ground.glb</filepath>
					<grouponly>false</grouponly>
				</item>
			</items>
			<itemvalues />
			<variables>
				<variable type="float4x4" name="viewProj" system="ViewProjection" />
				<variable type="float" name="uTime" system="Time" />
			</variables>
			<macros />
		</pass>
		<pass name="morph" type="shader" active="false" patchverts="10">
			<shader type="vs" path="shaders\Week2_morphVS.glsl" entry="main" />
			<shader type="ps" path="shaders\Week2_morphPS.glsl" entry="main" />
			<inputlayout>
				<item value="Position" semantic="POSITION" />
				<item value="Normal" semantic="NORMAL" />
				<item value="Texcoord" semantic="TEXCOORD0" />
			</inputlayout>
			<rendertexture />
			<items>
				<item name="scene_base" type="geometry">
					<type>Sphere</type>
					<width>1</width>
					<height>1</height>
					<depth>1</depth>
					<pitch>0.0174532924</pitch>
					<topology>TriangleList</topology>
				</item>
			</items>
			<itemvalues />
			<variables>
				<variable type="float4x4" name="viewProj" system="ViewProjection" />
				<variable type="float" name="uTime" system="Time" />
			</variables>
			<macros />
		</pass>
		<pass name="ProceduralTexture" type="shader" active="false" patchverts="1">
			<shader type="vs" path="shaders\Week2_ProceduralTextureVS.glsl" entry="main" />
			<shader type="ps" path="shaders\Week2_ProceduralTexturePS.glsl" entry="main" />
			<inputlayout>
				<item value="Position" semantic="POSITION" />
				<item value="Normal" semantic="NORMAL" />
				<item value="Texcoord" semantic="TEXCOORD0" />
			</inputlayout>
			<rendertexture />
			<items>
				<item name="ground2" type="model">
					<filepath>shaders\models\ground.glb</filepath>
					<grouponly>false</grouponly>
					<y>1</y>
				</item>
			</items>
			<itemvalues />
			<variables>
				<variable type="float" name="uTime" system="Time" />
				<variable type="float4x4" name="viewProj" system="ViewProjection" />
			</variables>
			<macros />
		</pass>
	</pipeline>
	<objects />
	<cameras />
	<settings>
		<entry type="property" name="ground2" item="pipe" />
		<entry type="camera" fp="false">
			<distance>17</distance>
			<pitch>19</pitch>
			<yaw>351</yaw>
			<roll>360</roll>
